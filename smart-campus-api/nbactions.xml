<?xml version="1.0" encoding="UTF-8"?>
<!--
    Tells NetBeans how to handle the built-in Run / Debug / Profile actions
    for this Maven project. Without this file NetBeans does not know that
    com.westminster.smartcampus.App is a runnable main class, so the Run
    button does nothing useful.
-->
<actions>

    <action>
        <actionName>run</actionName>
        <packagings>
            <packaging>jar</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.1.0:exec</goal>
        </goals>
        <properties>
            <exec.args>-classpath %classpath com.westminster.smartcampus.App</exec.args>
            <exec.executable>java</exec.executable>
            <exec.vmArgs></exec.vmArgs>
        </properties>
    </action>

    <action>
        <actionName>debug</actionName>
        <packagings>
            <packaging>jar</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.1.0:exec</goal>
        </goals>
        <properties>
            <exec.args>-agentlib:jdwp=transport=dt_socket,server=n,address=${jpda.address} -classpath %classpath com.westminster.smartcampus.App</exec.args>
            <exec.executable>java</exec.executable>
            <jpda.listen>true</jpda.listen>
        </properties>
    </action>

    <action>
        <actionName>profile</actionName>
        <packagings>
            <packaging>jar</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.1.0:exec</goal>
        </goals>
        <properties>
            <exec.args>${profiler.args} -classpath %classpath com.westminster.smartcampus.App</exec.args>
            <exec.executable>${profiler.java}</exec.executable>
            <exec.vmArgs></exec.vmArgs>
        </properties>
    </action>

</actions>
